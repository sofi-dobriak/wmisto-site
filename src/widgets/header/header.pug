    -
      const header_social_links = [
        { icon: 'facebook', href: '#' },
        { icon: 'inst', href: '#' },
        { icon: 'whatsapp', href: '#' },
        { icon: 'telegram', href: '#' },
        { icon: 'tiktok', href: '#' },
        { icon: 'youtube', href: '#' }
      ]
    
    .links-container 
      ul.header-social-list
        each item in header_social_links
          li.social-item
            a(href=item.href).social-link
              svg.social-icon.real 
                use(href=`/images/icons.svg#icon-${item.icon}`)
              svg.social-icon.fake
                use(href=`/images/icons.svg#icon-${item.icon}`)
      
      button(type="button").pdf-btn.js-pdf-popup-open
        svg.pdf-icon
          use(href="/images/icons.svg#icon-pdf")
        span.pdf-text.hide-on-tablet.hide-on-mobile  PDF Презентація
        span.pdf-text.hide-on-desktop.hide-on-mobile PDF 
      
      a(href="tel:380970000077").phone-link.hide-on-tablet.hide-on-mobile
        svg.phone-icon
          use(href="/images/icons.svg#icon-phone")
        span.phone-text +38 (097) 000-00-77

      button(type="button").general-btn.call-popup-btn.js-call-popup-open
        span.call-text.general-text.hide-on-mobile Зворотній дзвінок
        <svg class="call-icon hide-on-tablet hide-on-desktop" xmlns="http://www.w3.org/2000/svg" fill="none">
