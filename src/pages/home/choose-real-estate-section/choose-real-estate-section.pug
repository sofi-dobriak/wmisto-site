include /shared/components/general-btn/general-btn.pug

-
  const cards = [
    { title: 'Однокімнатні', area: 'Від 34 м²', img: 'one-room.jpg', alt: 'Interior', reverse: false },
    { title: 'Двокімнатні', area: 'Від 48 м²', img: 'two-room.jpg', alt: 'Interior', reverse: false },
    { title: 'Трикімнатні', area: 'Від 69 м²', img: 'three-room.jpg', alt: 'Interior', reverse: false },
    { title: 'Квартири з видами на фонтан', area: 'Від 20 м²', img: 'fountain.jpg', alt: 'Fountain', reverse: true },
    { title: 'З терасами', area: 'Від 34 м²', img: 'terrace.jpg', alt: 'Terrace', reverse: true },
    { title: 'Пентхауси', area: 'Від 8 м²', img: 'penthouse.jpg', alt: 'Penthouse', reverse: true }
  ]

section.choose-real-estate(id="choose-real-estate")
  .choose-title-block 
    h2.choose-title ПІДІБРАТИ нерухомість
    +general-btn({href: '/plannings.html', text: 'Переглянути усі планування'})

  .choose-grid
    each card, index in cards
      a.grid-link(href="/plannings.html" class=`item-${index + 1}`) 
        .grid-item
          .grid-item-content
            if card.reverse
              p.grid-item-area= card.area
              h3.grid-item-title= card.title
            else
              h3.grid-item-title= card.title
              p.grid-item-area= card.area
            
            .grid-item-image-block
              img.grid-item-image(src=`/images/choose-real-estate/${card.img}`, alt=card.alt)
