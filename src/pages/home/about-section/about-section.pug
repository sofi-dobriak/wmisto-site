        .swiper-slide
          img.slider-img-big(src="/images/about/about-main-4.jpg", alt="")
        .swiper-slide
          img.slider-img-big(src="/images/about/about-main-5.jpg", alt="")
        .swiper-slide
          img.slider-img-big(src="/images/about/about-main-6.jpg", alt="")

      p.main-count
        span.current 
