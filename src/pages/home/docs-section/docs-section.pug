-
  const docs_cards = [
    {
      img: '/images/docs/docs-img-1.jpg', 
      title:'Лiцензiя Г. П. Командор ( повiдомлення, перелiк робiт, Витяг iз сайту ДАБI )',
      link: '#'
    },
    {
      img: '/images/docs/docs-img-2.jpg', 
      title:'Договір оренди земельної ділянки від 12.06.2020р',
      link: '#'
    },
    {
      img: '/images/docs/docs-img-3.jpg', 
      title:'Eкспертиза проєкту',
      link: '#'
    },
    {
      img: '/images/docs/docs-img-4.jpg', 
      title:'2020-11-26 ГП Цедика 14А Стадия П - КОРРЕКТ-2 ГП',
      link: '#'
    }
  ]

section.docs-section(id="documents")
  h2.docs-title Документація
  
  ul.docs-list 
    each item in docs_cards 
      li.docs-item
        a(href=item.link).docs-link

          .docs-title-image-block
            .docs-image-block 
              img(src=item.img, alt=item.title).docs-image

            h3.docs-item-title
              span= item.title 

          svg(xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none").docs-icon
            line(x1="21" y1="12" x2="5" y2="12" stroke="currentColor" stroke-width="1").icon-line
            path(d="M9.35254 5.89844L2.94238 12.3076L9.35254 18.7178" stroke="currentColor" stroke-width="1").icon-arrowhead 
